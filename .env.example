# =====================================================================
# KIABI AI Guide — environment configuration
# Copy this file to `.env.local` and fill in the values for production.
# NEVER commit real secrets. These values are read on the SERVER only.
# =====================================================================

# --- Admin access (server-side gate) ---------------------------------
# The email allowed to access the admin back-office.
ADMIN_EMAIL=martin.delaporte@kiabi.com

# Admin password. In development, if left empty, a documented demo
# password ("kiabi-demo") is accepted so the dashboard can be previewed.
# In production you MUST set this (or, better, wire real SSO — see README).
ADMIN_PASSWORD=

# Secret used to sign the admin session cookie (HMAC). Use a long random
# string in production, e.g. `openssl rand -hex 32`.
ADMIN_SESSION_SECRET=change-me-in-production-please-use-a-long-random-string
